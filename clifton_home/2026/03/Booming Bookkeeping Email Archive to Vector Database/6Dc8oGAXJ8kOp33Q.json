tVal = !processedThreadIds.includes(email.json.threadId);\n  // console.log(`retval for ${email.json.threadId}`, retVal)\n  return retVal\n});\n\nconsole.log(\"unprocessedEmails\", unprocessedEmails)\n\nreturn unprocessedEmails;"},"id":"17508ad2-6bcf-4608-bc01-01745256e070","name":"Filter Unprocessed Emails","type":"n8n-nodes-base.code","typeVersion":2,"position":[1072,304]},{"parameters":{"jsCode":"const items = $input.all();\nconst config = $('Workflow Configuration').first().json;\n\n// // Filter by age if processAllEmails is false\nlet filteredItems = items;\n\n// if (!config.processAllEmails) {\n//   filteredItems = items.filter(item => {\n//     const emailDate = new Date(item.json.date);\n//     const now = new Date();\n//     const daysDiff = Math.floor((now - emailDate) / (1000 * 60 * 60 * 24));\n    \n//     return daysDiff >= config.minDaysOld && daysDiff <= config.maxDaysOld;\n//   });\n// }\n\n// Remove duplicates by threadId - keep only the first occurrence of each thread\nconst seenThreadIds = new Set();\nconst uniqueItems = [];\n\nfor (const item of filteredItems) {\n  const threadId = item.json.threadId;\n  \n  if (!seenThreadIds.has(threadId)) {\n    seenThreadIds.add(threadId);\n    uniqueItems.push(item);\n  }\n}\n\nreturn uniqueItems;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[1248,304],"id":"c275adfd-fcc9-4643-92a6-57647077ba23","name":"Filter and Deduplicate Emails"},{"parameters":{"amount":10},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[2544,656],"id":"97bf88e0-76eb-46f5-8749-8968fd7deae4","name":"Wait","webhookId":"efc97597-34c7-49a9-b0e0-738197153a34"},{"parameters":{"mode":"chooseBranch"},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[928,304],"id":"cda0c70b-f81f-4233-90cf-66e5f54a660a","name":"Merge"}],"connections":{"Workflow Configuration":{"main":[[{"node":"Get Emails from Gmail","type":"main","index":0},{"node":"Get Processed Email IDs","type":"main","index":0},{"node":"Get Emails from Gmail