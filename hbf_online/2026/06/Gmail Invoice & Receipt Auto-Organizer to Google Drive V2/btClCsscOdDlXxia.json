, token: '[CARD-REDACTED]' },\n];\n\nreturn $input.all().map(item => {\n  let safeSubject = item.json.subject || '';\n  let safeBody = item.json.text || item.json.html || '';\n\n  for (const p of patterns) {\n    safeSubject = safeSubject.replace(p.regex, p.token);\n    safeBody = safeBody.replace(p.regex, p.token);\n  }\n\n  const fromAddr = item.json.from?.value?.[0]?.address || item.json.from || '';\n  const domain = (fromAddr.split('@')[1] || '').toLowerCase();\n\n  return {\n    json: {\n      ...item.json,\n      sender_domain: domain,\n      subject_original: item.json.subject,\n      body_original: item.json.text,\n      subject: safeSubject,\n      body: safeBody,\n    },\n    binary: item.binary || {}\n  };\n});\n"}}],"connections":{"Extract Email Metadata":{"main":[[{"node":"Get Receipts Folder","type":"main","index":0}]]},"Get Receipts Folder":{"main":[[{"node":"Search Year Folder","type":"main","index":0}]]},"Search Year Folder":{"main":[[{"node":"Resolve Year Folder","type":"main","index":0}]]},"Resolve Year Folder":{"main":[[{"node":"Year Folder Exists?","type":"main","index":0}]]},"Year Folder Exists?":{"main":[[{"node":"Set Year Folder ID","type":"main","index":0},{"node":"Search Vendor Folder","type":"main","index":0}],[{"node":"Create Year Folder","type":"main","index":0}]]},"Create Year Folder":{"main":[[{"node":"Set Year Folder ID","type":"main","index":0}]]},"Search Vendor Folder":{"main":[[{"node":"Resolve Vendor Folder","type":"main","index":0}]]},"Resolve Vendor Folder":{"main":[[{"node":"Vendor Folder Exists?","type":"main","index":0}]]},"Vendor Folder Exists?":{"main":[[{"node":"Set Vendor Folder ID","type":"main","index":0},{"node":"Upload Attachment to Drive","type":"main","index":0}],[{"node":"Create Vendor Folder","type":"main","index":0}]]},"Create Vendor Folder":{"main":[[{"node":"Set Vendor Folder ID","type":"main","index":0}]]},"Upload Attachment to Drive":{"main":[[{"node":"Search Log Spreadsheet","type":"main","index":0}]]},"Sear