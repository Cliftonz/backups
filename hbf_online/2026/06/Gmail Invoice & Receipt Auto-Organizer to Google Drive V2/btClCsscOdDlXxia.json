{"updatedAt":"2026-06-26T16:47:22.292Z","createdAt":"2026-06-26T16:37:18.753Z","id":"btClCsscOdDlXxia","name":"Gmail Invoice & Receipt Auto-Organizer to Google Drive V2","description":"VA automation: pulls Gmail invoices and receipts weekly on Fridays, deduplicates, saves to Google Drive under Accounting/Receipts/YYYY/VendorName/ and logs to Google Sheet.","active":false,"isArchived":false,"nodes":[{"parameters":{"rule":{"interval":[{"field":"cronExpression","expression":"0 8 * * 5"}]}},"id":"9299ae66-72a7-47a4-a342-e0c1044949d9","name":"Watch Gmail for Invoices & Receipts","type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.3,"position":[0,96]},{"parameters":{"jsCode":"\nconst now = new Date();\nconst year = now.getFullYear().toString();\nconst monthTabName = now.toLocaleString('en-US', { month: 'long', year: 'numeric' });\nconst dateProcessed = now.toISOString().split('T')[0];\n\nconst results = [];\nfor (const item of $input.all()) {\n  const subject = item.json.subject || '';\n  const from = item.json.from?.value?.[0]?.address || item.json.from?.text || 'unknown';\n  const fromText = item.json.from?.text || '';\n  const fromName = item.json.from?.value?.[0]?.name || '';\n  const emailDate = item.json.date ? new Date(item.json.date).toISOString().split('T')[0] : dateProcessed;\n\n  let senderFolder = 'Unknown';\n  if (fromText.toLowerCase().includes('heyreach') || fromName.toLowerCase().includes('heyreach') || subject.toLowerCase().includes('heyreach')) {\n    senderFolder = 'Heyreach';\n  } else if (fromName && fromName !== from) {\n    senderFolder = fromName.replace(/[^a-zA-Z0-9 ]/g, '').trim().substring(0, 30);\n  } else {\n    const emailMatch = from.match(/@([^.]+)/);\n    const senderKey = emailMatch ? emailMatch[1] : from.split('@')[0];\n    senderFolder = senderKey.charAt(0).toUpperCase() + senderKey.slice(1);\n  }\n\n  const subjectLower = subject.toLowerCase();\n  let docType = 'Receipt';\n  if (subjectLower.includes('invoice') || subjectLower.includes('billing statement')) {\n    docType = 'Invoice';\n  }\n\n  const attachmentKeys = Object.keys(item.binary || {}).filter(k => k.startsWith('attachment_'));\n  if (attachmentKeys.length > 0) {\n    for (const attachKey of attachmentKeys) {\n      results.push({\n        json: {\n          docType,\n          senderFolder,\n          year,\n          monthTabName,\n          dateProcessed,\n          emailDate,\n          subject,\n          from,\n          fileName: item.binary[attachKey]?.fileName || attachKey + '.pdf'\n        },\n        binary: { data: item.binary[attachKey] }\n      });\n    }\n  }\n}\nreturn results;\n"},"id":"f0e17765-5b68-4a4a-b53d-a93b38b54e64","name":"Extract Email Metadata","type":"n8n-nodes-base.code","typeVersion":2,"position":[448,96]},{"parameters":{"resource":"fileFolder","queryString":"Receipts","limit":1,"filter":{"driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"id","value":"1ov1esrgadbn2qNDggi6IpHwkWNg-ad8X"},"whatToSearch":"folders"},"options":{}},"id":"1defb4d7-67f9-4542-a09c-7284792e23db","name":"Get Receipts Folder","type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[672,96],"executeOnce":true,"credentials":{"googleDriveOAuth2Api":{"id":"hcsZcalky3kETbKa","name":"Google Drive account 2"}}},{"parameters":{"resource":"fileFolder","queryString":"={{ $(\"Extract Email Metadata\").item.json.year }}","limit":1,"filter":{"folderId":{"__rl":true,"value":"={{ $json.id }}","mode":"id"},"whatToSearch":"folders"},"options":{"fields":["id","name"]}},"id":"29085c75-60f9-4e4e-b80f-2da1243ef274","name":"Search Year Folder","type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[896,96],"executeOnce":true,"alwaysOutputData":true,"credentials":{"googleDriveOAuth2Api":{"id":"hcsZcalky3kETbKa","name":"Google Drive account 2"}}},{"parameters":{"jsCode":"const items = $input.all();\nconst meta = $(\"Extract Email Metadata\").first();\nconst expectedYear = meta.json.year;\nconst match = items.find(i => (i.json.name || \"\") === expectedYear);\nreturn [{ json: { ...meta.json, year: meta.json.year, yearFolderId: match ? match.json.id : \"\", yearExists: !!match }, binary: meta.binary || {} }];"},"id":"1be0a21e-f36e-49a9-ba14-d1d0babe496f","name":"Resolve Year Folder","type":"n8n-nodes-base.code","typeVersion":2,"position":[1120,96]},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":3},"conditions":[{"leftValue":"={{ $json.yearExists }}","operator":{"type":"boolean","operation":"true"},"rightValue":true,"id":"29bb96ee-51f3-468b-94db-57b590583241"}],"combinator":"and"},"options":{}},"id":"35e0a649-315f-4a08-9230-0ad5dc3ee843","name":"Year Folder Exists?","type":"n8n-nodes-base.if","typeVersion":2.3,"position":[1344,96],"executeOnce":true,"retryOnFail":true},{"parameters":{"mode":"runOnceForEachItem","jsCode":"const meta = $input.item.json;\nif (meta.yearExists) {\n  return { json: { ...meta }, binary: $input.item.binary || {} };\n} else {\n  const createdFolder = $(\"Create Year Folder\").item.json;\n  return { json: { ...meta, yearFolderId: createdFolder.id }, binary: $input.item.binary || {} };\n}"},"id":"bf6d2fa2-d122-4953-b6ab-cf13894f7d5b","name":"Set Year Folder ID","type":"n8n-nodes-base.code","typeVersion":2,"position":[1792,96],"executeOnce":true,"retryOnFail":true},{"parameters":{"resource":"folder","name":"={{ $(\"Extract Email Metadata\").item.json.year }}","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"id","value":"1yFf6yOaRqyseUTE5T7OzpyQq9oXRww6Y"},"options":{}},"id":"a6f38bd0-82a2-4c06-9b63-c05324f8715b","name":"Create Year Folder","type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[1568,288],"executeOnce":true,"retryOnFail":true,"credentials":{"googleDriveOAuth2Api":{"id":"hcsZcalky3kETbKa","name":"Google Drive account 2"}}},{"parameters":{"resource":"fileFolder","queryString":"={{ $(\"Extract Email Metadata\").item.jso